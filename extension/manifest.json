{
  "manifest_version": 3,
  "name": "NotExtension",
  "version": "1.0",
  "action": {
    "default_popup": "popup/index.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],

  "options_ui": {
    "page": "popup/options.html",
    "open_in_tab": true
  }
}
